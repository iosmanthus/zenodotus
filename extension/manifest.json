{
  "manifest_version": 3,
  "name": "Zenodotus",
  "version": "0.1.0",
  "description": "Intelligent LLM-powered tab grouping",
  "permissions": ["tabs", "tabGroups", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
